{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ErrorResponse",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "Error type URI"
    },
    "title": {
      "type": "string",
      "description": "Short error description"
    },
    "code": {
      "type": "integer",
      "description": "Error code"
    },
    "detail": {
      "type": "string",
      "description": "Detailed error message"
    }
  }
}